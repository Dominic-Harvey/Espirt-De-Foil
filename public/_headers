# Cache video files for 1 year
/*.mp4
  Cache-Control: public, max-age=31536000, immutable

# Cache fonts for 1 year (since they are in your dependency tree)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Cache CSS/JS (Vite hashes these, so it's safe to cache forever)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
